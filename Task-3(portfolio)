transform:scale(1.1);
}

/* projects */

.project{
background:rgba(255,255,255,0.06);
padding:25px;
margin:20px auto;
max-width:600px;
border-radius:10px;
border-left:4px solid #38bdf8;
text-align:left;
transition:0.3s;
}

.project:hover{
transform:translateY(-6px);
background:rgba(255,255,255,0.1);
}

/* contact */

.contact p{
margin:8px;
font-size:17px;
}

/* footer */

footer{
text-align:center;
padding:25px;
margin-top:40px;
background:rgba(0,0,0,0.6);
